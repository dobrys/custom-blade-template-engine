# .env.example  в git (без реални стойности)
# .env         НЕ git (реални стойности)

# -------------------------------------------------------
# Application
# -------------------------------------------------------
APP_ENV=development
APP_DEBUG=true

# -------------------------------------------------------
# Security
# -------------------------------------------------------
JWT_SECRET=смени-с-дълъг-случаен-низ-минимум-32-символа

# -------------------------------------------------------
# Database
# -------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=my_database
DB_USER=my_user
DB_PASSWORD=смени-с-истинска-парола

# -------------------------------------------------------
# API Keys
# -------------------------------------------------------
API_KEY=смени-с-истински-ключ